# Vertex AI (Nano Banana / Imagen 3)
# 인증 우선순위: 1) BASE64 2) 파일경로 3) keys/credentials.b64

# 방법 A: Base64 인코딩된 JSON (Vercel 등에 적합)
# GOOGLE_APPLICATION_CREDENTIALS_BASE64=ewogICJ0eXBlIjo...

# 방법 B: JSON 파일 경로 (상대 또는 절대, Windows는 D:/path 형식 권장)
# GOOGLE_APPLICATION_CREDENTIALS=keys/your-service-account.json

# 방법 C: keys/credentials.b64 파일만 있으면 자동 사용 (로컬용)

GOOGLE_CLOUD_PROJECT=pixs-489916
GOOGLE_CLOUD_LOCATION=us-central1
